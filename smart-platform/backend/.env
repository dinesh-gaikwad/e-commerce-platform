# ===============================
# 🌐 SERVER CONFIG
# ===============================
PORT=5000
NODE_ENV=development


# ===============================
# 🗄️ DATABASE
# ===============================
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce


# ===============================
# 🔐 JWT AUTH
# ===============================
JWT_SECRET=supersecretkey
JWT_EXPIRE=7d


# ===============================
# 💳 RAZORPAY
# ===============================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key


# ===============================
# 🌍 FRONTEND URL (CORS)
# ===============================
CLIENT_URL=http://localhost:3000