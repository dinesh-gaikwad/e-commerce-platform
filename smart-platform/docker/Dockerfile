# ===============================
# 🐳 BASE IMAGE
# ===============================
FROM node:20

# ===============================
# 📁 WORKING DIRECTORY
# ===============================
WORKDIR /app

# ===============================
# 📦 COPY PACKAGE FILES
# ===============================
COPY backend/package*.json ./

# ===============================
# 📥 INSTALL DEPENDENCIES
# ===============================
RUN npm install

# ===============================
# 📂 COPY ALL BACKEND CODE
# ===============================
COPY backend .

# ===============================
# 🌍 ENVIRONMENT
# ===============================
ENV NODE_ENV=production
ENV PORT=5000

# ===============================
# 🚀 START SERVER
# ===============================
CMD ["node", "server.js"]

# ===============================
# 🔓 EXPOSE PORT
# ===============================
EXPOSE 5000